@startuml uml_summary
skinparam dpi 150
skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty members

package "«z innych pakietów»" <<Frame>> {
  class LinguisticVariable
  class Label
  class Quantifier
  class CarRecord
}

package "config" {
  class FuzzyConfig {
    -variables: Map<String,LinguisticVariable>
    -relativeQuantifiers: List<Quantifier>
    -absoluteQuantifiers: List<Quantifier>
    --
    +defaults(): FuzzyConfig
    +variables(): List
    +relativeQuantifiers(): List
    +absoluteQuantifiers(): List
    +addLabel(column,name,mf): void
    +addRelativeQuantifier(name,mf): void
    +addAbsoluteQuantifier(name,mf): void
  }
}

package "summary" {
  interface LabelExpression {
    +degree(rec): double
    +text(): String
    +atoms(): List
  }
  class Property {
    -variable: LinguisticVariable
    -label: Label
  }
  enum "Connective.Kind" as ConnectiveKind {
    AND
    OR
  }
  class Connective {
    -kind: Kind
    -parts: List<LabelExpression>
  }
  class SingleSubjectSummary {
    -quantifier: Quantifier
    -qualifier: LabelExpression
    -summarizer: LabelExpression
    --
    +sentence(): String
    +hasQualifier(): boolean
  }
  class SummaryGenerator {
    -config: FuzzyConfig
    --
    +simpleForm1(abs): List
    +compoundForm1(kind,a,b): List
    +simpleForm2(col,label): List
  }
}

package "summary.quality" {
  class QualityMeasures <<utility>> {
    +evaluate(summary,records,weights): Quality
  }
  class Quality <<record>> {
    +t1..t11: double
    +optimal: double
    {static}+NAMES: String[]
    --
    +toArray(): double[]
  }
  class QualityWeights {
    -weights: double[]
    --
    +equal(): QualityWeights
    +weightedSum(m): double
  }
}

Connective +-- ConnectiveKind
LabelExpression <|.. Property
LabelExpression <|.. Connective
Property --> LinguisticVariable
Property --> Label
Connective --> "*" LabelExpression
SingleSubjectSummary --> Quantifier
SingleSubjectSummary --> LabelExpression
SummaryGenerator --> FuzzyConfig
SummaryGenerator ..> SingleSubjectSummary
FuzzyConfig --> "*" LinguisticVariable
FuzzyConfig --> "*" Quantifier
QualityMeasures ..> SingleSubjectSummary
QualityMeasures ..> Quality
QualityMeasures ..> QualityWeights
LabelExpression ..> CarRecord
@enduml

