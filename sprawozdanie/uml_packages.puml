' Diagramy klas rozbite na pakiety (pionowe, mieszczące się w normalnych marginesach).
' Klasy z innych pakietów pokazano jako odnośniki (puste boksy) w grupie
' "«z innych pakietów»", by zachować strzałki zależności bez duplikowania definicji.
' Render (Graphviz/dot zalecany):
'   java -DPLANTUML_LIMIT_SIZE=16384 -jar plantuml.jar -tpng -o plots uml_packages.puml

' =====================================================================
@startuml uml_fuzzy
skinparam dpi 150
skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty members

package "fuzzy.set" {
  enum "Universe.Kind" as UniverseKind {
    DISCRETE
    CONTINUOUS
  }
  class Universe {
    -min: double
    -max: double
    -kind: Kind
    -sampleCount: int
    -cachedSamples: double[]
    {static}-DEFAULT_SAMPLES: int
    {static}-MAX_DISCRETE_SAMPLES: int
    --
    +continuous(min,max): Universe
    +discrete(min,max): Universe
    +samplePoints(): double[]
    +clamp(x): double
  }
  class FuzzySet {
    -name: String
    -universe: Universe
    -mf: MembershipFunction
    {static}-EPS: double
    --
    +membership(x): double
    +height(): double
    +support(): Interval
    +alphaCut(a): Interval
    +isNormal()/isEmpty()/isConvex(): boolean
    +complement()/union()/intersect(): FuzzySet
    +relativeSupportCardinality(): double
    +relativeSigmaCardinality(): double
  }
  class ClassicSet {
    -name: String
    -universe: Universe
    -predicate: DoublePredicate
    --
    +membership(x): double
    +complement()/union()/intersect(): ClassicSet
  }
  class Interval <<record>> {
    +lo: double
    +hi: double
    +empty: boolean
  }
}

package "fuzzy.mf" {
  interface MembershipFunction <<functional>> {
    +degree(x): double
  }
  class TriangularMf {
    -a: double
    -b: double
    -c: double
    -delegate: MembershipFunctionTriangular
  }
  class TrapezoidalMf {
    -a: double
    -b: double
    -c: double
    -d: double
    -delegate: MembershipFunctionTrapetzoidal
  }
  class GaussianMf {
    -mean: double
    -sigma: double
    -delegate: MembershipFunctionGaussian
  }
  class Operations <<utility>> {
    +complement(mf): MembershipFunction
    +union(a,b): MembershipFunction
    +intersection(a,b): MembershipFunction
  }
}

package "fuzzy.linguistic" {
  enum "Quantifier.Type" as QuantifierType {
    RELATIVE
    ABSOLUTE
  }
  class LinguisticVariable {
    -name: String
    -column: String
    -universe: Universe
    -labels: List<Label>
    --
    +degreeOf(label,x): double
    +isValid(x): boolean
  }
  class Label <<record>> {
    +name: String
    +set: FuzzySet
    --
    +degree(x): double
  }
  class Quantifier {
    -name: String
    -type: Type
    -set: FuzzySet
    --
    +degree(quantity): double
    +isRelative(): boolean
  }
}

Universe +-- UniverseKind
Quantifier +-- QuantifierType
MembershipFunction <|.. TriangularMf
MembershipFunction <|.. TrapezoidalMf
MembershipFunction <|.. GaussianMf
FuzzySet --> Universe
FuzzySet --> MembershipFunction
FuzzySet ..> Interval
ClassicSet --> Universe
Operations ..> MembershipFunction
Label --> FuzzySet
LinguisticVariable --> Universe
LinguisticVariable --> "*" Label
Quantifier --> FuzzySet
@enduml

