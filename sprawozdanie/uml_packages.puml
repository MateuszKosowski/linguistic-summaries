@startuml uml_multi
skinparam dpi 150
skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty members

package "«z innych pakietów»" <<Frame>> {
  class Quantifier
  interface LabelExpression
  class FuzzyConfig
  class CarRecord
}

package "summary.multi" {
  enum "MultiSubjectSummary.Form" as MultiSubjectForm {
    I
    II
    III
    IV
  }
  class Subject {
    -name: String
    -predicate: Predicate<CarRecord>
    --
    +ofMake(make): Subject
    +contains(rec): boolean
  }
  class MultiSubjectSummary {
    -form: Form
    -quantifier: Quantifier
    -p1: Subject
    -p2: Subject
    -summarizer: LabelExpression
    -qualifier: LabelExpression
    --
    +formI/II/III/IV(...): MultiSubjectSummary
    +sentence(): String
  }
  class MultiSubjectMeasures <<utility>> {
    +degreeOfTruth(summary,records): double
  }
  class MultiSubjectGenerator {
    -config: FuzzyConfig
    --
    +formI(p1,p2): List
    +formII(p1,p2,s2): List
    +formIII(p1,p2,s2): List
    +formIV(p1,p2): List
  }
}

MultiSubjectSummary +-- MultiSubjectForm
MultiSubjectSummary --> Quantifier
MultiSubjectSummary --> "2" Subject
MultiSubjectSummary --> LabelExpression
MultiSubjectMeasures ..> MultiSubjectSummary
MultiSubjectGenerator --> FuzzyConfig
MultiSubjectGenerator ..> MultiSubjectSummary
Subject ..> CarRecord
@enduml

